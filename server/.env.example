# Server port and bind address (use 0.0.0.0 on Termux so the device browser can reach the API)
PORT=3000
HOST=0.0.0.0

# SQLite database file (sql.js — no native better-sqlite3)
# Termux (after termux-setup-storage):
# DB_PATH=/sdcard/Documents/ExpenseTracker/expense_tracker.db
DB_PATH=./data/expense_tracker.db

# Firebase Admin SDK (required for authenticated API routes)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Optional: monthly report emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Admin panel JWT (optional)
JWT_SECRET=change-me-in-production

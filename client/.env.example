# Local / Termux (same device — matches start_termux.sh)
VITE_API_URL=http://127.0.0.1:3000/api

# Or use Vite dev proxy (relative path; vite.config.ts proxies /api -> :3000)
# VITE_API_URL=/api

# Remote access via ngrok (replace with your tunnel URL + /api)
# VITE_API_URL=https://your-subdomain.ngrok-free.dev/api

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
